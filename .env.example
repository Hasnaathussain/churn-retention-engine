# -----------------------------------------------------------------------------
# Anchoryn environment reference
# Copy this file to `.env` for local development.
# Never commit real secrets to git.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Shared application settings
# -----------------------------------------------------------------------------
APP_ENV=development
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Frontend / Next.js
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/v1
NEXT_PUBLIC_AUTH_COOKIE_NAME=anchoryn_access_token
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_ALLOW_DEMO_MODE=true
NEXT_PUBLIC_DEMO_VIDEO_URL=

# -----------------------------------------------------------------------------
# Auth / session security
# Required for any live auth deployment.
# -----------------------------------------------------------------------------
AUTH_JWT_SECRET=replace_with_a_long_random_secret
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
REMEMBER_ME_DAYS=30

# -----------------------------------------------------------------------------
# Demo / seeded preview mode
# Keep enabled for local previews. Disable in production unless intentional.
# -----------------------------------------------------------------------------
ALLOW_DEMO_MODE=true
DEMO_WORKSPACE_ID=org_demo_anchoryn
DEMO_WORKSPACE_NAME=Anchoryn Launch Preview

# -----------------------------------------------------------------------------
# AI provider
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_LIVE_ENABLED=false

# -----------------------------------------------------------------------------
# Stripe billing
# -----------------------------------------------------------------------------
STRIPE_API_KEY=sk_test_your_stripe_key
STRIPE_LIVE_ENABLED=false
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID=price_your_monthly_price_id
STRIPE_CUSTOMER_ID=

# -----------------------------------------------------------------------------
# Email / notifications
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your_resend_key
SUPPORT_EMAIL=support@anchoryn.com

# -----------------------------------------------------------------------------
# Product / analytics integrations
# -----------------------------------------------------------------------------
MIXPANEL_PROJECT_TOKEN=
INTERCOM_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Supabase compatibility layer
# The frontend still supports a Supabase fallback path while the backend-owned
# auth cutover is in progress.
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_LIVE_ENABLED=false

# -----------------------------------------------------------------------------
# Planned production services
# These are documented for the launch architecture even though the current repo
# has not fully wired each service yet.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/churn_retention
REDIS_URL=redis://localhost:6379/0
SENTRY_DSN=
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
